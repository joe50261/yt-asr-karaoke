{
  "manifest_version": 3,
  "name": "YouTube Caption Karaoke",
  "description": "Turns YouTube auto-captions into a full-line karaoke overlay with real per-word highlighting (no simulated timing).",
  "version": "1.1.0",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "YouTube Caption Karaoke",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "yk-di.js",
        "yk-config.js",
        "yk-log.js",
        "yk-settings.js",
        "yk-timing.js",
        "yk-parse.js",
        "yk-yt.js",
        "yk-ui.js",
        "yk-capture.js",
        "yk-styles.js",
        "yk-overlay.js",
        "yk-transcript.js",
        "yk-panel.js",
        "yk-autodrive.js",
        "yk-native.js",
        "yk-engine.js",
        "yk-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
